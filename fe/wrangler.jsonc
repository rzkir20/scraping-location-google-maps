{
	"compatibility_date": "2026-04-06",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "scraping-location-google-maps",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"vars": {
		"PUBLIC_API_URL": "http://127.0.0.1:8080"
	},
	"observability": {
		"enabled": true
	}
}