---
import Button from "./ui/Button.astro";

import DialogDesktop from "./DialogDesktop.astro";

import DialogSocial from "./DialogSocial.astro";

import DialogSettings from "./DialogSettings.astro";

import Label from "./ui/Label.astro";

import Sheets from "./ui/Sheets.astro";

import SidebarSearchForm from "./SidebarSearchForm.astro";

import { scrapMapsApiBase } from "../lib/config";

const apiBase = scrapMapsApiBase;
---

<div
  class="flex h-screen min-h-0 w-full flex-col overflow-hidden bg-[#0f0f0f] lg:flex-row"
>
  <!-- Sidebar desktop (≥ lg); mobile pakai Sheets + hamburger -->
  <aside
    class="z-30 hidden h-full w-[320px] shrink-0 flex-col border-r border-[#2d2d2d] bg-[#161616] lg:flex"
  >
    <div
      class="flex shrink-0 items-center gap-3 border-b border-[#2d2d2d] p-4 sm:p-6"
    >
      <div
        class="flex h-8 w-8 items-center justify-center rounded-lg bg-[#0066cc]"
      >
        <iconify-icon icon="lucide:map-pin" class="text-lg text-white"
        ></iconify-icon>
      </div>
      <span
        class="min-w-0 truncate text-base font-semibold tracking-tight sm:text-lg"
        >MapsScraper Pro</span
      >
    </div>
    <div
      class="min-h-0 flex-1 space-y-8 overflow-y-auto p-4 custom-scrollbar sm:p-6"
    >
      <SidebarSearchForm idSuffix="" />
    </div>
    <div class="shrink-0 border-t border-[#2d2d2d] p-4 sm:p-6">
      <Button variant="primary" id="start-scrape-btn">
        <iconify-icon icon="lucide:play-circle"></iconify-icon>
        Start Scraping
      </Button>
    </div>
  </aside>

  <main
    class="relative flex min-h-0 min-w-0 flex-1 flex-col overflow-x-hidden overflow-y-auto custom-scrollbar"
  >
    <header
      class="flex min-h-16 shrink-0 flex-wrap items-center justify-between gap-x-2 gap-y-2 border-b border-[#2d2d2d] bg-[#161616] px-3 py-2.5 sm:h-16 sm:min-h-0 sm:flex-nowrap sm:px-6 sm:py-0"
    >
      <div class="flex min-w-0 flex-1 flex-wrap items-center gap-2 sm:gap-4">
        <Button
          variant="ghost"
          id="sidebar-menu-trigger"
          class="lg:hidden"
          ariaLabel="Buka pencarian"
          ariaExpanded={false}
          ariaControls="sidebar-search-sheet"
        >
          <iconify-icon icon="lucide:menu" class="text-xl"></iconify-icon>
        </Button>
        <div
          id="header-status-pill"
          class="flex max-w-full min-w-0 items-center gap-2 rounded-full border px-2.5 py-1 text-[11px] font-medium sm:px-3 sm:text-xs bg-amber-500/10 border-amber-500/20 text-amber-400"
        >
          <span
            id="header-status-dot"
            class="w-2 h-2 rounded-full bg-amber-400 animate-pulse shrink-0"
          ></span>
          <span id="header-status-text" class="truncate">Mengecek backend…</span
          >
        </div>
        <div class="h-4 w-px bg-[#2d2d2d] hidden sm:block"></div>
        <div
          class="hidden min-w-0 flex-wrap items-center gap-x-3 gap-y-1 text-sm text-gray-400 md:flex lg:max-w-[min(100%,24rem)]"
        >
          <span class="max-w-[min(100%,14rem)] truncate lg:max-w-xs">
            <span class="text-white font-medium">API:</span>
            <span id="header-api-url" class="font-mono text-[11px]"
              >{apiBase}</span
            >
          </span>
          <span class="h-3 w-px bg-[#2d2d2d] shrink-0" aria-hidden="true"
          ></span>
          <span class="shrink-0">
            <span class="text-white font-medium">Proxy:</span>
            <span id="header-proxy-label" class="text-gray-300"
              >Aktif (DE-104)</span
            >
          </span>
        </div>
      </div>
      <div class="flex shrink-0 items-center gap-0.5 sm:gap-2">
        <Button
          variant="soft"
          id="download-app-trigger"
          ariaLabel="Download aplikasi desktop"
        >
          <iconify-icon
            icon="lucide:download-cloud"
            class="text-lg sm:text-base"></iconify-icon>
          <span class="hidden sm:inline">Download App</span>
        </Button>
        <div class="relative shrink-0" id="notification-anchor">
          <Button
            variant="ghostNotify"
            id="notification-trigger"
            ariaLabel="Notifikasi"
            ariaExpanded={false}
            ariaHaspopup={true}
            ariaControls="notification-panel"
          >
            <iconify-icon icon="lucide:bell" class="text-xl"></iconify-icon>
            <span
              id="notification-dot"
              class="pointer-events-none absolute top-1.5 right-1.5 w-2 h-2 rounded-full bg-[#0066cc] ring-2 ring-[#161616] hidden"
              aria-hidden="true"></span>
          </Button>
          <div
            id="notification-panel"
            role="region"
            aria-label="Daftar notifikasi"
            class="absolute top-full right-0 mt-2 w-[min(calc(100vw-2rem),20rem)] rounded-xl border border-[#2d2d2d] bg-[#161616] shadow-2xl z-90 hidden max-h-[min(70vh,22rem)] overflow-hidden"
          >
            <div
              class="px-4 py-3 border-b border-[#2d2d2d] flex items-center justify-between gap-2 shrink-0"
            >
              <span class="text-sm font-bold text-white">Notifikasi</span>
              <Button
                variant="textLinkAccent"
                id="notification-clear-all"
                type="button"
              >
                Hapus semua
              </Button>
            </div>
            <div
              id="notification-list"
              class="overflow-y-auto custom-scrollbar flex-1 p-2 min-h-16"
            >
            </div>
          </div>
        </div>
        <Button
          variant="ghost"
          id="settings-modal-trigger"
          ariaLabel="Settings"
        >
          <iconify-icon icon="lucide:settings" class="text-xl"></iconify-icon>
        </Button>
        <Button
          variant="ghostHeart"
          id="social-modal-trigger"
          ariaLabel="Follow us"
        >
          <iconify-icon icon="lucide:heart" class="text-xl"></iconify-icon>
        </Button>
      </div>
    </header>

    <div
      id="dashboard-split"
      class="flex w-full flex-1 flex-col min-h-screen lg:flex-row"
    >
      <!-- Map: parent flex-1 + min-h supaya kontainer punya tinggi untuk Leaflet -->
      <div
        id="map-stage"
        class="relative flex-1 min-h-[80dvh] overflow-hidden border-b border-[#2d2d2d] bg-[#1a1a1a] shadow-inner sm:min-h-[52dvh] lg:min-h-0 lg:border-b-0 lg:border-r"
      >
        <div
          class="absolute inset-0 opacity-10 pointer-events-none"
          style="background-image: radial-gradient(#444 1px, transparent 1px); background-size: 32px 32px;"
        >
        </div>
        <div
          class="absolute inset-0 opacity-20 bg-[url('https://www.transparenttextures.com/patterns/stardust.png')]"
        >
        </div>

        <div
          id="map-preview"
          class="absolute inset-0 z-5 size-full min-h-0"
          aria-label="Peta preview"
        >
        </div>
        <div
          id="map-idle-banner"
          class="pointer-events-none absolute bottom-20 left-1/2 z-15 max-w-[min(92vw,420px)] -translate-x-1/2 rounded-lg border border-[#2d2d2d] bg-[#161616]/95 px-3 py-2 text-center text-[10px] text-gray-400 shadow-lg backdrop-blur-sm sm:bottom-14 sm:px-4 sm:text-[11px]"
        >
          <span class="font-semibold text-[#0066cc]">Peta preview</span>
          · OSM + Carto (gelap). Titik
          <span class="text-gray-500">contoh</span>
          sebelum scraping. Setelah
          <strong class="text-gray-300">Start Scraping</strong>, peta fokus ke
          lokasi (geocode) + hasil.
        </div>

        <div
          class="absolute left-3 top-14 z-20 w-[min(15rem,calc(100vw-4.5rem))] max-h-[min(62vh,28rem)] space-y-2 overflow-y-auto overflow-x-hidden [scrollbar-width:thin] sm:left-6 sm:top-6 sm:max-h-none sm:w-60 sm:max-w-[min(15rem,calc(100%-7rem))] sm:space-y-3 sm:overflow-visible custom-scrollbar"
        >
          <div
            class="rounded-xl border border-[#2d2d2d] bg-[#161616]/95 p-3 shadow-2xl backdrop-blur-md sm:p-4"
          >
            <div class="mb-4 flex items-center justify-between">
              <div class="min-w-0">
                <p
                  class="text-[10px] font-bold uppercase tracking-widest text-gray-500"
                >
                  Total Scraped
                </p>
                <p
                  id="dash-total-scraped"
                  class="font-mono text-2xl font-bold text-white"
                >
                  —
                </p>
              </div>
              <div class="shrink-0 text-right">
                <p
                  class="text-[10px] font-bold uppercase tracking-widest text-gray-500"
                >
                  Avg Rating
                </p>
                <div class="flex items-center justify-end gap-1 text-[#FFD700]">
                  <iconify-icon icon="lucide:star" class="text-[#FFD700]"
                  ></iconify-icon>
                  <p class="font-mono text-xl font-bold text-white">4.3</p>
                </div>
              </div>
            </div>
            <div class="space-y-2">
              <p
                class="text-[10px] font-bold uppercase tracking-widest text-gray-500"
              >
                Rating Distribution
              </p>
              <div class="space-y-1.5">
                <div class="flex items-center gap-2">
                  <span class="w-4 shrink-0 text-[10px] text-gray-400">5★</span>
                  <div
                    class="h-1.5 flex-1 overflow-hidden rounded-full bg-gray-800"
                  >
                    <div class="h-full w-[45%] bg-[#FFD700]"></div>
                  </div>
                  <span class="text-[10px] text-gray-500">45%</span>
                </div>
                <div class="flex items-center gap-2">
                  <span class="w-4 shrink-0 text-[10px] text-gray-400">4★</span>
                  <div
                    class="h-1.5 flex-1 overflow-hidden rounded-full bg-gray-800"
                  >
                    <div class="h-full w-[35%] bg-[#0066cc]"></div>
                  </div>
                  <span class="text-[10px] text-gray-500">35%</span>
                </div>
                <div class="flex items-center gap-2">
                  <span class="w-4 shrink-0 text-[10px] text-gray-400">3★</span>
                  <div
                    class="h-1.5 flex-1 overflow-hidden rounded-full bg-gray-800"
                  >
                    <div class="h-full w-[15%] bg-[#FF8C00]"></div>
                  </div>
                  <span class="text-[10px] text-gray-500">15%</span>
                </div>
              </div>
            </div>
          </div>
          <div
            class="flex flex-col gap-2 rounded-xl border border-[#2d2d2d] bg-[#161616]/95 p-3 backdrop-blur-md"
          >
            <div class="flex items-center justify-between gap-2">
              <div class="flex min-w-0 items-center gap-2">
                <div
                  id="live-progress-dot"
                  class="h-2 w-2 shrink-0 rounded-full bg-gray-500"
                >
                </div>
                <span
                  class="truncate text-xs font-bold uppercase tracking-widest text-gray-400"
                  >Live tracking</span
                >
              </div>
              <span
                id="live-progress-label"
                class="shrink-0 font-mono text-[10px] text-[#0066cc]"
                >0 / 0</span
              >
            </div>
            <div class="h-1.5 w-full overflow-hidden rounded-full bg-gray-800">
              <div
                id="live-progress-fill"
                class="h-full rounded-full bg-[#0066cc] transition-[width] duration-300 ease-out"
                style="width: 0%"
              >
              </div>
            </div>
          </div>
          <div
            class="rounded-xl border border-[#2d2d2d] bg-[#161616]/95 p-3 backdrop-blur-md"
          >
            <Label variant="caption">Current Card</Label>
            <div class="mt-2 space-y-1">
              <p
                id="live-card-name"
                class="truncate text-xs font-semibold text-white sm:whitespace-normal sm:wrap-break-word"
              >
                Menunggu kartu...
              </p>
              <p class="text-[10px] text-gray-500">
                Rating: <span id="live-card-rating">-</span>
              </p>
              <p id="live-card-category" class="text-[10px] text-gray-500">-</p>
              <p
                id="live-card-address"
                class="text-[10px] leading-relaxed text-gray-400 wrap-break-word"
              >
                -
              </p>
              <p class="text-[10px] text-gray-500">
                <span id="live-card-opening">-</span>
                <span class="text-gray-600"> • </span>
                <span id="live-card-phone" class="font-mono">-</span>
              </p>
            </div>
          </div>
          <div
            class="max-h-40 overflow-y-auto rounded-xl border border-[#2d2d2d] bg-[#161616]/95 p-3 backdrop-blur-md custom-scrollbar"
          >
            <Label variant="caption">Log scraping</Label>
            <pre
              id="scrape-log"
              class="m-0 text-[10px] font-mono leading-relaxed text-gray-400 wrap-break-word whitespace-pre-wrap">Menunggu job…</pre>
          </div>
        </div>

        <div
          class="absolute right-3 top-3 z-30 flex rounded-lg border border-[#2d2d2d] bg-[#161616]/95 p-0.5 shadow-xl sm:right-6 sm:top-6 sm:p-1"
        >
          <Button variant="toggleOn" id="map-view-toggle" type="button">
            <iconify-icon icon="lucide:map"></iconify-icon>
            <span class="hidden sm:inline">Map</span>
          </Button>
          <Button variant="toggleOff" id="list-view-toggle" type="button">
            <iconify-icon icon="lucide:list"></iconify-icon>
            <span class="hidden sm:inline">List</span>
          </Button>
        </div>

        <div
          class="absolute bottom-6 left-6 z-20 bg-[#161616]/95 backdrop-blur-md border border-[#2d2d2d] p-3 rounded-xl shadow-xl space-y-2 max-sm:hidden"
        >
          <Label variant="legend">Rating Legend</Label>
          <div class="grid grid-cols-1 gap-1.5">
            <div class="flex items-center gap-2">
              <div class="w-2.5 h-2.5 rounded-full bg-[#FFD700]"></div>
              <span class="text-[10px] text-gray-400">5.0 Stars</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-2.5 h-2.5 rounded-full bg-[#0066cc]"></div>
              <span class="text-[10px] text-gray-400">4.0 - 4.9</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-2.5 h-2.5 rounded-full bg-[#FF8C00]"></div>
              <span class="text-[10px] text-gray-400">3.0 - 3.9</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-2.5 h-2.5 rounded-full bg-[#FF4444]"></div>
              <span class="text-[10px] text-gray-400">2.0 - 2.9</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-2.5 h-2.5 rounded-full bg-[#666666]"></div>
              <span class="text-[10px] text-gray-400">Below 2.0</span>
            </div>
          </div>
        </div>

        <div
          class="absolute bottom-4 right-4 z-20 flex flex-col gap-1.5 sm:bottom-6 sm:right-6 sm:gap-2"
        >
          <Button
            variant="mapTool"
            id="map-zoom-in"
            type="button"
            ariaLabel="Zoom in"
          >
            <iconify-icon icon="lucide:plus" class="text-lg"></iconify-icon>
          </Button>
          <Button
            variant="mapTool"
            id="map-zoom-out"
            type="button"
            ariaLabel="Zoom out"
          >
            <iconify-icon icon="lucide:minus" class="text-lg"></iconify-icon>
          </Button>
          <Button
            variant="mapTool"
            id="map-recenter"
            type="button"
            class="mt-2"
            ariaLabel="Recenter"
          >
            <iconify-icon icon="lucide:navigation-2" class="text-lg"
            ></iconify-icon>
          </Button>
        </div>
      </div>

      <!-- Results panel -->
      <div
        id="results-panel"
        class="flex min-h-[min(20rem,42dvh)] w-full shrink-0 flex-col overflow-hidden bg-[#161616] h-full lg:min-h-0 lg:w-[300px] overflow-y-auto custom-scrollbar"
      >
        <div
          class="p-4 border-b border-[#2d2d2d] flex items-center justify-between gap-2"
        >
          <h3 id="results-heading" class="text-sm font-semibold">
            Results (0)
          </h3>
          <div class="flex items-center gap-2">
            <Button variant="iconSq" type="button" ariaLabel="Filter">
              <iconify-icon icon="lucide:filter"></iconify-icon>
            </Button>
            <Button variant="iconSq" type="button" ariaLabel="Columns">
              <iconify-icon icon="lucide:columns"></iconify-icon>
            </Button>
          </div>
        </div>
        <div
          class="flex-1 overflow-x-auto overflow-y-auto custom-scrollbar min-h-0"
        >
          <table
            class="w-full text-left border-collapse min-w-[420px]"
            id="results-table"
          >
            <thead
              class="sticky top-0 bg-[#161616] z-10 border-b border-[#2d2d2d]"
            >
              <tr
                class="text-[10px] font-semibold text-gray-500 uppercase tracking-widest"
              >
                <th class="px-4 py-3">Name</th>
                <th class="px-4 py-3">Rating</th>
                <th class="px-4 py-3">Phone</th>
                <th class="px-4 py-3 text-right">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-[#2d2d2d]" id="results-tbody"></tbody>
          </table>
        </div>
        <div class="p-4 border-t border-[#2d2d2d] bg-[#1a1a1a] shrink-0">
          <div
            class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-4"
          >
            <div class="flex flex-wrap gap-2">
              <Button variant="outline" id="export-csv-btn" type="button">
                <iconify-icon icon="lucide:file-text"></iconify-icon> CSV
              </Button>
              <Button variant="outline" id="export-json-btn" type="button">
                <iconify-icon icon="lucide:code"></iconify-icon> JSON
              </Button>
              <Button variant="outline" id="export-xlsx-btn" type="button">
                <iconify-icon icon="lucide:table"></iconify-icon> EXCEL
              </Button>
            </div>
          </div>
          <div
            class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 text-xs text-gray-500"
          >
            <p id="results-pagination-text">Belum ada data</p>
            <div class="flex gap-1">
              <Button
                variant="pagination"
                type="button"
                ariaLabel="Previous page"
              >
                <iconify-icon icon="lucide:chevron-left"></iconify-icon>
              </Button>
              <Button variant="paginationActive" type="button">1</Button>
              <Button variant="pagination" type="button">2</Button>
              <Button variant="pagination" type="button">3</Button>
              <Button variant="pagination" type="button" ariaLabel="Next page">
                <iconify-icon icon="lucide:chevron-right"></iconify-icon>
              </Button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Analytics strip -->
    <section
      class="shrink-0 overflow-x-auto border-t border-[#2d2d2d] bg-[#0f0f0f] p-4 pb-[max(1rem,env(safe-area-inset-bottom))] custom-scrollbar sm:p-6"
    >
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 min-w-0">
        <div
          class="bg-[#161616] border border-[#2d2d2d] rounded-2xl p-5 hover:border-[#0066cc]/50 transition-all group shadow-lg"
        >
          <div class="flex items-center justify-between mb-4">
            <Label variant="cardTitle" as="h4">Location Summary</Label>
            <iconify-icon
              icon="lucide:info"
              class="text-gray-600 group-hover:text-[#0066cc] transition-colors"
            ></iconify-icon>
          </div>
          <div class="space-y-4">
            <div>
              <span
                id="dash-footer-total"
                class="block text-3xl font-bold text-white">—</span
              >
              <span
                class="text-[10px] text-gray-500 font-bold uppercase tracking-tighter"
                >Total Businesses Found</span
              >
            </div>
            <div class="grid grid-cols-2 gap-4 pt-2 border-t border-[#2d2d2d]">
              <div>
                <span class="block text-lg font-bold text-white"
                  >4.6<span class="text-xs text-gray-500">/5</span></span
                >
                <span class="text-[9px] text-gray-500 uppercase font-bold"
                  >Avg Rating</span
                >
              </div>
              <div>
                <span class="block text-lg font-bold text-[#0066cc] truncate"
                  >Dining</span
                >
                <span class="text-[9px] text-gray-500 uppercase font-bold"
                  >Top Category</span
                >
              </div>
            </div>
          </div>
        </div>
        <div
          class="bg-[#161616] border border-[#2d2d2d] rounded-2xl p-5 hover:border-[#0066cc]/50 transition-all group shadow-lg"
        >
          <div class="flex items-center justify-between mb-4">
            <Label variant="cardTitle" as="h4">Rating Distribution</Label>
            <iconify-icon
              icon="lucide:bar-chart-3"
              class="text-gray-600 group-hover:text-[#0066cc] transition-colors"
            ></iconify-icon>
          </div>
          <div class="space-y-2">
            <div class="flex items-center gap-2">
              <span class="text-[10px] w-4 text-gray-500 font-bold">5★</span>
              <div
                class="flex-1 h-1.5 bg-gray-800 rounded-full overflow-hidden"
              >
                <div class="h-full bg-[#0066cc] w-[45%]"></div>
              </div>
              <span class="text-[10px] text-gray-400 font-mono w-6 text-right"
                >456</span
              >
            </div>
            <div class="flex items-center gap-2">
              <span class="text-[10px] w-4 text-gray-500 font-bold">4★</span>
              <div
                class="flex-1 h-1.5 bg-gray-800 rounded-full overflow-hidden"
              >
                <div class="h-full bg-[#0066cc]/80 w-[38%]"></div>
              </div>
              <span class="text-[10px] text-gray-400 font-mono w-6 text-right"
                >389</span
              >
            </div>
            <div class="flex items-center gap-2">
              <span class="text-[10px] w-4 text-gray-500 font-bold">3★</span>
              <div
                class="flex-1 h-1.5 bg-gray-800 rounded-full overflow-hidden"
              >
                <div class="h-full bg-[#0066cc]/60 w-[25%]"></div>
              </div>
              <span class="text-[10px] text-gray-400 font-mono w-6 text-right"
                >254</span
              >
            </div>
            <div class="flex items-center gap-2">
              <span class="text-[10px] w-4 text-gray-500 font-bold">2★</span>
              <div
                class="flex-1 h-1.5 bg-gray-800 rounded-full overflow-hidden"
              >
                <div class="h-full bg-[#0066cc]/40 w-[10%]"></div>
              </div>
              <span class="text-[10px] text-gray-400 font-mono w-6 text-right"
                >98</span
              >
            </div>
            <div class="flex items-center gap-2">
              <span class="text-[10px] w-4 text-gray-500 font-bold">1★</span>
              <div
                class="flex-1 h-1.5 bg-gray-800 rounded-full overflow-hidden"
              >
