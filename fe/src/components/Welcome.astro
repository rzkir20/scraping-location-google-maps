---
import Dialog from "./ui/Dialog.astro";
import Input from "./ui/Input.astro";
import Button from "./ui/Button.astro";
import Label from "./ui/Label.astro";

const apiBase = import.meta.env.PUBLIC_API_URL ?? "http://127.0.0.1:8080";
---

<div class="flex h-screen w-full overflow-hidden bg-[#0f0f0f]">
  <!-- Sidebar -->
  <aside
    class="w-[min(100%,320px)] sm:w-[320px] h-full bg-[#161616] border-r border-[#2d2d2d] flex flex-col shrink-0 z-30 max-sm:max-h-[40vh] max-sm:border-b max-sm:border-r-0"
  >
    <div class="p-6 border-b border-[#2d2d2d] flex items-center gap-3">
      <div
        class="w-8 h-8 bg-[#0066cc] rounded-lg flex items-center justify-center"
      >
        <iconify-icon icon="lucide:map-pin" class="text-white text-lg"
        ></iconify-icon>
      </div>
      <span class="text-lg font-semibold tracking-tight">MapsScraper Pro</span>
    </div>
    <div class="flex-1 overflow-y-auto custom-scrollbar p-6 space-y-8">
      <section>
        <Label variant="section">Basic Search</Label>
        <div class="space-y-4">
          <Input
            variant="field"
            id="input-keyword"
            type="text"
            placeholder="Search business/keywords..."
            icon="lucide:search"
          />
          <Input
            variant="field"
            id="input-location"
            type="text"
            placeholder="Location (e.g. Bandung, Jakarta)"
            icon="lucide:navigation"
          />
          <Input
            variant="field"
            id="input-max-results"
            type="number"
            min={1}
            max={500}
            value={10}
            placeholder="10"
            title="Target listing (tanpa website, wajib ada nomor telepon)"
            icon="lucide:hash"
          />
          <p class="text-[10px] text-gray-500 leading-relaxed">
            Target = jumlah listing tanpa website + ada nomor (sama seperti
            aplikasi Go). Dari FE, backend jalan <strong class="text-gray-400"
              >headless</strong
            > (tanpa jendela Chrome). Progres tampil di
            <strong class="text-gray-400">Live tracking</strong> + log.
          </p>
        </div>
      </section>
      <section>
        <Label variant="section">Filters & Parameters</Label>
        <div class="space-y-4">
          <div>
            <div class="flex justify-between text-xs mb-2">
              <span>Radius</span>
              <span class="text-[#0066cc] font-medium"
                ><span id="radius-label">15</span> km</span
              >
            </div>
            <Input
              variant="range"
              id="input-radius"
              min={1}
              max={50}
              value={15}
            />
          </div>
          <div>
            <Input
              variant="select"
              selectClass="w-full bg-[#1f1f1f] border border-[#2d2d2d] rounded-lg py-2 px-3 text-sm focus:outline-none focus:border-[#0066cc] text-gray-200"
            >
              <option>All Categories</option>
              <option>Restaurants</option>
              <option>Real Estate</option>
              <option>Legal Services</option>
              <option>Dental Clinics</option>
            </Input>
          </div>
          <div class="flex gap-2 text-sm">
            <div
              class="flex-1 bg-[#1f1f1f] border border-[#2d2d2d] rounded-lg p-2 text-center cursor-pointer hover:border-[#0066cc] transition-colors"
            >
              <span class="block text-[10px] text-gray-500 uppercase"
                >Min Rating</span
              >
              <span>4.0+</span>
            </div>
            <div
              class="flex-1 bg-[#1f1f1f] border border-[#2d2d2d] rounded-lg p-2 text-center cursor-pointer hover:border-[#0066cc] transition-colors"
            >
              <span class="block text-[10px] text-gray-500 uppercase"
                >Reviews</span
              >
              <span>50+</span>
            </div>
          </div>
        </div>
      </section>
      <section>
        <Label variant="section">Bulk Operations</Label>
        <div
          class="border-2 border-dashed border-[#2d2d2d] rounded-xl p-4 text-center hover:border-[#0066cc] transition-colors group cursor-pointer"
        >
          <iconify-icon
            icon="lucide:upload-cloud"
            class="text-2xl text-gray-500 group-hover:text-[#0066cc] transition-colors mb-2"
          ></iconify-icon>
          <p class="text-xs text-gray-400">Drop CSV for bulk search</p>
        </div>
      </section>
      <section>
        <details class="group">
          <summary
            class="list-none flex justify-between items-center cursor-pointer text-xs font-semibold text-gray-500 uppercase tracking-wider"
          >
            Advanced Settings
            <iconify-icon
              icon="lucide:chevron-down"
              class="group-open:rotate-180 transition-transform"></iconify-icon>
          </summary>
          <div class="pt-4 space-y-3">
            <Input variant="checkbox" checked={true}>
              <span class="text-sm text-gray-400">Skip existing records</span>
            </Input>
            <Input variant="checkbox">
              <span class="text-sm text-gray-400">Scrape email addresses</span>
            </Input>
          </div>
        </details>
      </section>
    </div>
    <div class="p-6 border-t border-[#2d2d2d]">
      <Button variant="primary" id="start-scrape-btn">
        <iconify-icon icon="lucide:play-circle"></iconify-icon>
        Start Scraping
      </Button>
    </div>
  </aside>

  <main
    class="flex-1 flex flex-col min-w-0 min-h-0 overflow-y-auto custom-scrollbar relative"
  >
    <header
      class="h-16 bg-[#161616] border-b border-[#2d2d2d] flex items-center justify-between px-4 sm:px-6 shrink-0 gap-2"
    >
      <div class="flex items-center gap-2 sm:gap-4 min-w-0 flex-wrap">
        <div
          id="header-status-pill"
          class="flex items-center gap-2 px-3 py-1 rounded-full border text-xs font-medium bg-amber-500/10 border-amber-500/20 text-amber-400"
        >
          <span
            id="header-status-dot"
            class="w-2 h-2 rounded-full bg-amber-400 animate-pulse shrink-0"
          ></span>
          <span id="header-status-text" class="truncate">Mengecek backend…</span
          >
        </div>
        <div class="h-4 w-px bg-[#2d2d2d] hidden sm:block"></div>
        <div
          class="text-sm text-gray-400 hidden md:flex flex-wrap items-center gap-x-3 gap-y-1 min-w-0"
        >
          <span class="truncate max-w-[min(100%,14rem)] lg:max-w-xs">
            <span class="text-white font-medium">API:</span>
            <span id="header-api-url" class="font-mono text-[11px]"
              >{apiBase}</span
            >
          </span>
          <span class="h-3 w-px bg-[#2d2d2d] shrink-0" aria-hidden="true"
          ></span>
          <span class="shrink-0">
            <span class="text-white font-medium">Proxy:</span>
            <span id="header-proxy-label" class="text-gray-300"
              >Aktif (DE-104)</span
            >
          </span>
        </div>
      </div>
      <div class="flex items-center gap-0.5 sm:gap-2 shrink-0">
        <Button
          variant="soft"
          id="download-app-trigger"
          ariaLabel="Download aplikasi desktop"
        >
          <iconify-icon
            icon="lucide:download-cloud"
            class="text-lg sm:text-base"></iconify-icon>
          <span class="hidden sm:inline">Download App</span>
        </Button>
        <div class="relative shrink-0" id="notification-anchor">
          <Button
            variant="ghostNotify"
            id="notification-trigger"
            ariaLabel="Notifikasi"
            ariaExpanded={false}
            ariaHaspopup={true}
            ariaControls="notification-panel"
          >
            <iconify-icon icon="lucide:bell" class="text-xl"></iconify-icon>
            <span
              id="notification-dot"
              class="pointer-events-none absolute top-1.5 right-1.5 w-2 h-2 rounded-full bg-[#0066cc] ring-2 ring-[#161616] hidden"
              aria-hidden="true"></span>
          </Button>
          <div
            id="notification-panel"
            role="region"
            aria-label="Daftar notifikasi"
            class="absolute top-full right-0 mt-2 w-[min(calc(100vw-2rem),20rem)] rounded-xl border border-[#2d2d2d] bg-[#161616] shadow-2xl z-[90] hidden max-h-[min(70vh,22rem)] overflow-hidden"
          >
            <div
              class="px-4 py-3 border-b border-[#2d2d2d] flex items-center justify-between gap-2 shrink-0"
            >
              <span class="text-sm font-bold text-white">Notifikasi</span>
              <Button
                variant="textLinkAccent"
                id="notification-clear-all"
                type="button"
              >
                Hapus semua
              </Button>
            </div>
            <div
              id="notification-list"
              class="overflow-y-auto custom-scrollbar flex-1 p-2 min-h-[4rem]"
            >
            </div>
          </div>
        </div>
        <Button
          variant="ghost"
          id="settings-modal-trigger"
          ariaLabel="Settings"
        >
          <iconify-icon icon="lucide:settings" class="text-xl"></iconify-icon>
        </Button>
        <Button
          variant="ghostHeart"
          id="social-modal-trigger"
          ariaLabel="Follow us"
        >
          <iconify-icon icon="lucide:heart" class="text-xl"></iconify-icon>
        </Button>
      </div>
    </header>

    <div
      id="dashboard-split"
      class="flex flex-col lg:flex-row h-[min(600px,calc(100vh-64px))] lg:h-[calc(100vh-64px)] min-h-[480px] shrink-0"
    >
      <!-- Map stage -->
      <div
        id="map-stage"
        class="flex-1 relative bg-[#1a1a1a] overflow-hidden border-b lg:border-b-0 lg:border-r border-[#2d2d2d] shadow-inner min-h-[280px] lg:min-h-0"
      >
        <div
          class="absolute inset-0 opacity-10 pointer-events-none"
          style="background-image: radial-gradient(#444 1px, transparent 1px); background-size: 32px 32px;"
        >
        </div>
        <div
          class="absolute inset-0 opacity-20 bg-[url('https://www.transparenttextures.com/patterns/stardust.png')]"
        >
        </div>

        <div
          id="map-preview"
          class="absolute inset-0 z-[5] min-h-[200px]"
          aria-label="Peta preview"
        >
        </div>
        <div
          id="map-idle-banner"
          class="pointer-events-none absolute bottom-14 left-1/2 z-[15] max-w-[min(90%,420px)] -translate-x-1/2 rounded-lg border border-[#2d2d2d] bg-[#161616]/95 px-4 py-2 text-center text-[11px] text-gray-400 shadow-lg backdrop-blur-sm"
        >
          <span class="font-semibold text-[#0066cc]">Peta preview</span>
          · OSM + Carto (gelap). Titik
          <span class="text-gray-500">contoh</span>
          sebelum scraping. Setelah
          <strong class="text-gray-300">Start Scraping</strong>, peta fokus ke
          lokasi (geocode) + hasil.
        </div>

        <div
          class="absolute top-6 left-6 z-20 w-72 max-w-[calc(100%-3rem)] space-y-3"
        >
          <div
            class="bg-[#161616]/95 backdrop-blur-md border border-[#2d2d2d] p-4 rounded-xl shadow-2xl"
          >
            <div class="flex items-center justify-between mb-4">
              <div>
                <p
                  class="text-[10px] text-gray-500 uppercase tracking-widest font-bold"
                >
                  Total Scraped
                </p>
                <p
                  id="dash-total-scraped"
                  class="text-2xl font-bold font-mono text-white"
                >
                  —
                </p>
              </div>
              <div class="text-right">
                <p
                  class="text-[10px] text-gray-500 uppercase tracking-widest font-bold"
                >
                  Avg Rating
                </p>
                <div class="flex items-center gap-1 text-[#FFD700]">
                  <iconify-icon icon="lucide:star" class="text-[#FFD700]"
                  ></iconify-icon>
                  <p class="text-xl font-bold font-mono text-white">4.3</p>
                </div>
              </div>
            </div>
            <div class="space-y-2">
              <p
                class="text-[10px] text-gray-500 uppercase tracking-widest font-bold"
              >
                Rating Distribution
              </p>
              <div class="space-y-1.5">
                <div class="flex items-center gap-2">
                  <span class="text-[10px] w-4 text-gray-400">5★</span>
                  <div
                    class="flex-1 h-1.5 bg-gray-800 rounded-full overflow-hidden"
                  >
                    <div class="h-full bg-[#FFD700] w-[45%]"></div>
                  </div>
                  <span class="text-[10px] text-gray-500">45%</span>
                </div>
                <div class="flex items-center gap-2">
                  <span class="text-[10px] w-4 text-gray-400">4★</span>
                  <div
                    class="flex-1 h-1.5 bg-gray-800 rounded-full overflow-hidden"
                  >
                    <div class="h-full bg-[#0066cc] w-[35%]"></div>
                  </div>
                  <span class="text-[10px] text-gray-500">35%</span>
                </div>
                <div class="flex items-center gap-2">
                  <span class="text-[10px] w-4 text-gray-400">3★</span>
                  <div
                    class="flex-1 h-1.5 bg-gray-800 rounded-full overflow-hidden"
                  >
                    <div class="h-full bg-[#FF8C00] w-[15%]"></div>
                  </div>
                  <span class="text-[10px] text-gray-500">15%</span>
                </div>
              </div>
            </div>
          </div>
          <div
            class="bg-[#161616]/95 backdrop-blur-md border border-[#2d2d2d] p-3 rounded-xl flex flex-col gap-2"
          >
            <div class="flex items-center justify-between gap-2">
              <div class="flex items-center gap-2 min-w-0">
                <div
                  id="live-progress-dot"
                  class="w-2 h-2 rounded-full bg-gray-500 shrink-0"
                >
                </div>
                <span
                  class="text-xs text-gray-400 uppercase tracking-widest font-bold truncate"
                  >Live tracking</span
                >
              </div>
              <span
                id="live-progress-label"
                class="text-[10px] font-mono text-[#0066cc] shrink-0"
                >0 / 0</span
              >
            </div>
            <div class="w-full h-1.5 bg-gray-800 rounded-full overflow-hidden">
              <div
                id="live-progress-fill"
                class="h-full bg-[#0066cc] rounded-full transition-[width] duration-300 ease-out"
                style="width: 0%"
              >
              </div>
            </div>
          </div>
          <div
            class="bg-[#161616]/95 backdrop-blur-md border border-[#2d2d2d] p-3 rounded-xl max-h-40 overflow-y-auto custom-scrollbar"
          >
            <Label variant="caption">Log scraping</Label>
            <pre
              id="scrape-log"
              class="text-[10px] text-gray-400 font-mono whitespace-pre-wrap break-words m-0 leading-relaxed">Menunggu job…</pre>
          </div>
        </div>

        <div
          class="absolute top-6 right-6 z-20 flex bg-[#161616]/95 border border-[#2d2d2d] rounded-lg p-1 shadow-xl"
        >
          <Button variant="toggleOn" id="map-view-toggle" type="button">
            <iconify-icon icon="lucide:map"></iconify-icon> Map
          </Button>
          <Button variant="toggleOff" id="list-view-toggle" type="button">
            <iconify-icon icon="lucide:list"></iconify-icon> List
          </Button>
        </div>

        <div
          class="absolute bottom-6 left-6 z-20 bg-[#161616]/95 backdrop-blur-md border border-[#2d2d2d] p-3 rounded-xl shadow-xl space-y-2 max-sm:hidden"
        >
          <Label variant="legend">Rating Legend</Label>
          <div class="grid grid-cols-1 gap-1.5">
            <div class="flex items-center gap-2">
              <div class="w-2.5 h-2.5 rounded-full bg-[#FFD700]"></div>
              <span class="text-[10px] text-gray-400">5.0 Stars</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-2.5 h-2.5 rounded-full bg-[#0066cc]"></div>
              <span class="text-[10px] text-gray-400">4.0 - 4.9</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-2.5 h-2.5 rounded-full bg-[#FF8C00]"></div>
              <span class="text-[10px] text-gray-400">3.0 - 3.9</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-2.5 h-2.5 rounded-full bg-[#FF4444]"></div>
              <span class="text-[10px] text-gray-400">2.0 - 2.9</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-2.5 h-2.5 rounded-full bg-[#666666]"></div>
              <span class="text-[10px] text-gray-400">Below 2.0</span>
            </div>
          </div>
        </div>

        <div class="absolute bottom-6 right-6 z-20 flex flex-col gap-2">
          <Button
            variant="mapTool"
            id="map-zoom-in"
            type="button"
            ariaLabel="Zoom in"
          >
            <iconify-icon icon="lucide:plus" class="text-lg"></iconify-icon>
          </Button>
          <Button
            variant="mapTool"
            id="map-zoom-out"
            type="button"
            ariaLabel="Zoom out"
          >
            <iconify-icon icon="lucide:minus" class="text-lg"></iconify-icon>
          </Button>
          <Button
            variant="mapTool"
            id="map-recenter"
            type="button"
            class="mt-2"
            ariaLabel="Recenter"
          >
            <iconify-icon icon="lucide:navigation-2" class="text-lg"
            ></iconify-icon>
          </Button>
        </div>
      </div>

      <!-- Results panel -->
      <div
        id="results-panel"
        class="w-full lg:w-[500px] h-full bg-[#161616] flex flex-col shrink-0 overflow-hidden min-h-[320px]"
      >
        <div
          class="p-4 border-b border-[#2d2d2d] flex items-center justify-between gap-2"
        >
          <h3 id="results-heading" class="text-sm font-semibold">
            Results (0)
          </h3>
          <div class="flex items-center gap-2">
            <Button variant="iconSq" type="button" ariaLabel="Filter">
              <iconify-icon icon="lucide:filter"></iconify-icon>
            </Button>
            <Button variant="iconSq" type="button" ariaLabel="Columns">
              <iconify-icon icon="lucide:columns"></iconify-icon>
            </Button>
          </div>
        </div>
        <div
          class="flex-1 overflow-x-auto overflow-y-auto custom-scrollbar min-h-0"
        >
          <table
            class="w-full text-left border-collapse min-w-[420px]"
            id="results-table"
          >
            <thead
              class="sticky top-0 bg-[#161616] z-10 border-b border-[#2d2d2d]"
            >
              <tr
                class="text-[10px] font-semibold text-gray-500 uppercase tracking-widest"
              >
                <th class="px-4 py-3">Name</th>
                <th class="px-4 py-3">Rating</th>
                <th class="px-4 py-3">Phone</th>
                <th class="px-4 py-3 text-right">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-[#2d2d2d]" id="results-tbody"></tbody>
          </table>
        </div>
        <div class="p-4 border-t border-[#2d2d2d] bg-[#1a1a1a] shrink-0">
          <div
            class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-4"
          >
            <div class="flex flex-wrap gap-2">
              <Button variant="outline" id="export-csv-btn" type="button">
                <iconify-icon icon="lucide:file-text"></iconify-icon> CSV
              </Button>
              <Button variant="outline" id="export-json-btn" type="button">
                <iconify-icon icon="lucide:code"></iconify-icon> JSON
              </Button>
              <Button variant="outline" id="export-xlsx-btn" type="button">
                <iconify-icon icon="lucide:table"></iconify-icon> EXCEL
              </Button>
            </div>
          </div>
          <div
            class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 text-xs text-gray-500"
          >
            <p id="results-pagination-text">Belum ada data</p>
            <div class="flex gap-1">
              <Button
                variant="pagination"
                type="button"
                ariaLabel="Previous page"
              >
                <iconify-icon icon="lucide:chevron-left"></iconify-icon>
              </Button>
              <Button variant="paginationActive" type="button">1</Button>
              <Button variant="pagination" type="button">2</Button>
              <Button variant="pagination" type="button">3</Button>
              <Button variant="pagination" type="button" ariaLabel="Next page">
                <iconify-icon icon="lucide:chevron-right"></iconify-icon>
              </Button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Analytics strip -->
    <section
      class="p-6 bg-[#0f0f0f] border-t border-[#2d2d2d] shrink-0 overflow-x-auto custom-scrollbar"
    >
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 min-w-0">
        <div
          class="bg-[#161616] border border-[#2d2d2d] rounded-2xl p-5 hover:border-[#0066cc]/50 transition-all group shadow-lg"
        >
          <div class="flex items-center justify-between mb-4">
            <Label variant="cardTitle" as="h4">Location Summary</Label>
            <iconify-icon
              icon="lucide:info"
              class="text-gray-600 group-hover:text-[#0066cc] transition-colors"
            ></iconify-icon>
          </div>
          <div class="space-y-4">
            <div>
              <span
                id="dash-footer-total"
                class="block text-3xl font-bold text-white">—</span
              >
              <span
                class="text-[10px] text-gray-500 font-bold uppercase tracking-tighter"
                >Total Businesses Found</span
              >
            </div>
            <div class="grid grid-cols-2 gap-4 pt-2 border-t border-[#2d2d2d]">
              <div>
                <span class="block text-lg font-bold text-white"
                  >4.6<span class="text-xs text-gray-500">/5</span></span
                >
                <span class="text-[9px] text-gray-500 uppercase font-bold"
                  >Avg Rating</span
                >
              </div>
              <div>
                <span class="block text-lg font-bold text-[#0066cc] truncate"
                  >Dining</span
                >
                <span class="text-[9px] text-gray-500 uppercase font-bold"
                  >Top Category</span
                >
              </div>
            </div>
          </div>
        </div>
        <div
          class="bg-[#161616] border border-[#2d2d2d] rounded-2xl p-5 hover:border-[#0066cc]/50 transition-all group shadow-lg"
        >
          <div class="flex items-center justify-between mb-4">
            <Label variant="cardTitle" as="h4">Rating Distribution</Label>
            <iconify-icon
              icon="lucide:bar-chart-3"
              class="text-gray-600 group-hover:text-[#0066cc] transition-colors"
            ></iconify-icon>
          </div>
          <div class="space-y-2">
            <div class="flex items-center gap-2">
              <span class="text-[10px] w-4 text-gray-500 font-bold">5★</span>
              <div
                class="flex-1 h-1.5 bg-gray-800 rounded-full overflow-hidden"
              >
                <div class="h-full bg-[#0066cc] w-[45%]"></div>
              </div>
              <span class="text-[10px] text-gray-400 font-mono w-6 text-right"
                >456</span
              >
            </div>
            <div class="flex items-center gap-2">
              <span class="text-[10px] w-4 text-gray-500 font-bold">4★</span>
              <div
                class="flex-1 h-1.5 bg-gray-800 rounded-full overflow-hidden"
              >
                <div class="h-full bg-[#0066cc]/80 w-[38%]"></div>
              </div>
