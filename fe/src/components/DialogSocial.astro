---
import Dialog from "./ui/Dialog.astro";
---

<Dialog
  id="social-modal"
  zIndex={10010}
  panelClass="max-w-sm p-6"
  closeButtonClass="absolute top-4 right-4 text-gray-500 transition-colors hover:text-white"
  closeIconClass="text-xl"
>
  <div class="mb-6">
    <h2 class="text-xl font-bold text-white">Follow Us</h2>
    <p class="text-xs text-gray-500">Update fitur dan berita terbaru</p>
  </div>
  <div class="space-y-3">
    <a
      id="follow-twitter-link"
      href="https://twitter.com"
      target="_blank"
      rel="noopener noreferrer"
      class="group flex items-center justify-between rounded-xl border border-[#2d2d2d] bg-[#1f1f1f] p-3 transition-all hover:border-[#0066cc]/50"
    >
      <div class="flex min-w-0 items-center gap-3">
        <iconify-icon
          icon="mdi:twitter"
          class="shrink-0 text-2xl text-[#1DA1F2]"></iconify-icon>
        <div class="min-w-0">
          <p class="text-sm font-bold text-white">Twitter / X</p>
          <p class="truncate text-[10px] text-gray-500">@mapsscraper_pro</p>
        </div>
      </div>
      <span
        class="shrink-0 rounded-lg bg-[#0066cc]/10 px-3 py-1 text-[10px] font-bold uppercase text-[#0066cc] transition-all group-hover:bg-[#0066cc] group-hover:text-white"
        >Follow</span
      >
    </a>
    <a
      id="follow-linkedin-link"
      href="https://linkedin.com"
      target="_blank"
      rel="noopener noreferrer"
      class="group flex items-center justify-between rounded-xl border border-[#2d2d2d] bg-[#1f1f1f] p-3 transition-all hover:border-[#0066cc]/50"
    >
      <div class="flex min-w-0 items-center gap-3">
        <iconify-icon
          icon="mdi:linkedin"
          class="shrink-0 text-2xl text-[#0A66C2]"></iconify-icon>
        <div class="min-w-0">
          <p class="text-sm font-bold text-white">LinkedIn</p>
          <p class="truncate text-[10px] text-gray-500">MapsScraper Pro</p>
        </div>
      </div>
      <span
        class="shrink-0 rounded-lg bg-[#0066cc]/10 px-3 py-1 text-[10px] font-bold uppercase text-[#0066cc] transition-all group-hover:bg-[#0066cc] group-hover:text-white"
        >Follow</span
      >
    </a>
    <a
      id="follow-github-link"
      href="https://github.com"
      target="_blank"
      rel="noopener noreferrer"
      class="group flex items-center justify-between rounded-xl border border-[#2d2d2d] bg-[#1f1f1f] p-3 transition-all hover:border-[#0066cc]/50"
    >
      <div class="flex min-w-0 items-center gap-3">
        <iconify-icon icon="mdi:github" class="shrink-0 text-2xl text-white"
        ></iconify-icon>
        <div class="min-w-0">
          <p class="text-sm font-bold text-white">GitHub</p>
          <p class="truncate text-[10px] text-gray-500">
            @mapsscraper-official
          </p>
        </div>
      </div>
      <span
        class="shrink-0 rounded-lg bg-[#0066cc]/10 px-3 py-1 text-[10px] font-bold uppercase text-[#0066cc] transition-all group-hover:bg-[#0066cc] group-hover:text-white"
        >Follow</span
      >
    </a>
    <a
      id="follow-instagram-link"
      href="https://instagram.com"
      target="_blank"
      rel="noopener noreferrer"
      class="group flex items-center justify-between rounded-xl border border-[#2d2d2d] bg-[#1f1f1f] p-3 transition-all hover:border-[#0066cc]/50"
    >
      <div class="flex min-w-0 items-center gap-3">
        <iconify-icon
          icon="mdi:instagram"
          class="shrink-0 text-2xl text-[#E4405F]"></iconify-icon>
        <div class="min-w-0">
          <p class="text-sm font-bold text-white">Instagram</p>
          <p class="truncate text-[10px] text-gray-500">@mapsscraper.pro</p>
        </div>
      </div>
      <span
        class="shrink-0 rounded-lg bg-[#0066cc]/10 px-3 py-1 text-[10px] font-bold uppercase text-[#0066cc] transition-all group-hover:bg-[#0066cc] group-hover:text-white"
        >Follow</span
      >
    </a>
    <a
      id="follow-facebook-link"
      href="https://facebook.com"
      target="_blank"
      rel="noopener noreferrer"
      class="group flex items-center justify-between rounded-xl border border-[#2d2d2d] bg-[#1f1f1f] p-3 transition-all hover:border-[#0066cc]/50"
    >
      <div class="flex min-w-0 items-center gap-3">
        <iconify-icon
          icon="mdi:facebook"
          class="shrink-0 text-2xl text-[#1877F2]"></iconify-icon>
        <div class="min-w-0">
          <p class="text-sm font-bold text-white">Facebook</p>
          <p class="truncate text-[10px] text-gray-500">MapsScraper Pro</p>
        </div>
      </div>
      <span
        class="shrink-0 rounded-lg bg-[#0066cc]/10 px-3 py-1 text-[10px] font-bold uppercase text-[#0066cc] transition-all group-hover:bg-[#0066cc] group-hover:text-white"
        >Follow</span
      >
    </a>
  </div>
</Dialog>
