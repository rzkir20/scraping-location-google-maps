---
/**
 * Input dashboard gelap — dipakai ulang di sidebar / modal.
 * Field: ikon kiri opsional (Iconify). Buka/tutup dengan props `variant`.
 */
interface Props {
  variant?: "field" | "select" | "range" | "checkbox";
  id?: string;
  name?: string;
  type?: string;
  placeholder?: string;
  value?: string | number;
  min?: string | number;
  max?: string | number;
  step?: string | number;
  title?: string;
  disabled?: boolean;
  required?: boolean;
  checked?: boolean;
  autocomplete?: string;
  /** Iconify, contoh lucide:search — hanya variant field */
  icon?: string;
  iconClass?: string;
  wrapperClass?: string;
  /** Override penuh kelas input (field / range) */
  class?: string;
  /** Field: tambahan di atas default (jika `class` tidak di-set) */
  inputClass?: string;
  /** Select: kelas `<select>` */
  selectClass?: string;
  /** Select: ikon chevron kanan */
  showChevron?: boolean;
  /** Range: kelas pada input range */
  rangeClass?: string;
  /** Checkbox: kelas pada input */
  checkboxClass?: string;
}

const {
  variant = "field",
  id,
  name,
  type = "text",
  placeholder,
  value,
  min,
  max,
  step,
  title,
  disabled,
  required,
  checked,
  autocomplete,
  icon,
  iconClass = "absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 pointer-events-none",
  wrapperClass = "relative",
  class: className,
  inputClass = "",
  selectClass,
  showChevron = false,
  rangeClass = "w-full accent-[#0066cc]",
  checkboxClass,
} = Astro.props;

const fieldBase =
  "w-full bg-[#1f1f1f] border border-[#2d2d2d] rounded-lg py-2 text-sm focus:outline-none focus:border-[#0066cc] transition-colors text-gray-200 placeholder:text-gray-600";
const fieldPad = icon ? "pl-10 pr-4" : "px-4";
const mergedFieldClass =
  className ?? `${fieldBase} ${fieldPad} ${inputClass}`.trim();

const defaultSelectClass =
  "w-full bg-[#1f1f1f] border border-[#2d2d2d] rounded-xl py-3 px-4 pr-10 text-sm focus:outline-none focus:border-[#0066cc] appearance-none text-white";
const mergedSelectClass = selectClass ?? defaultSelectClass;

const defaultCheckboxClass =
  "w-4 h-4 rounded bg-[#1f1f1f] border-[#2d2d2d] text-[#0066cc] focus:ring-0";
const mergedCheckboxClass = checkboxClass ?? defaultCheckboxClass;

const hasCheckboxSlot = Astro.slots.has("default");
---

{
  variant === "field" && (
    <div class={wrapperClass}>
      {icon && <iconify-icon icon={icon} class={iconClass} />}
      <input
        id={id}
        name={name}
        type={type as astroHTML.JSX.HTMLInputTypeAttribute}
        placeholder={placeholder}
        class={mergedFieldClass}
        min={min != null ? String(min) : undefined}
        max={max != null ? String(max) : undefined}
        step={step != null ? String(step) : undefined}
        title={title}
        disabled={disabled}
        required={required}
        autocomplete={autocomplete}
        value={value != null && value !== "" ? String(value) : undefined}
      />
    </div>
  )
}

{
  variant === "select" && (
    <div class={wrapperClass}>
      <select
        id={id}
        name={name}
        class={mergedSelectClass}
        disabled={disabled}
        required={required}
        title={title}
      >
        <slot />
      </select>
      {showChevron && (
        <iconify-icon
          icon="lucide:chevron-down"
          class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 pointer-events-none"
        />
      )}
    </div>
  )
}

{
  variant === "range" && (
    <input
      id={id}
      name={name}
      type="range"
      class={className ?? rangeClass}
      min={min != null ? String(min) : undefined}
      max={max != null ? String(max) : undefined}
      step={step != null ? String(step) : undefined}
      value={value != null ? String(value) : undefined}
      title={title}
      disabled={disabled}
    />
  )
}

{
  variant === "checkbox" &&
    (hasCheckboxSlot ? (
      <label class="flex items-center gap-3 cursor-pointer">
        <input
          type="checkbox"
          id={id}
          name={name}
          class={mergedCheckboxClass}
          checked={checked}
          disabled={disabled}
          required={required}
          title={title}
        />
        <slot />
      </label>
    ) : (
      <input
        type="checkbox"
        id={id}
        name={name}
        class={mergedCheckboxClass}
        checked={checked}
        disabled={disabled}
        required={required}
        title={title}
      />
    ))
}
