---
import Dialog from "./ui/Dialog.astro";
import Label from "./ui/Label.astro";
import Input from "./ui/Input.astro";
import Button from "./ui/Button.astro";
---

<!-- Settings + sound -->
<Dialog
  id="settings-modal"
  zIndex={10020}
  panelClass="max-w-2xl max-h-[90vh] overflow-y-auto custom-scrollbar p-6 sm:p-8"
>
  <div class="mb-8">
    <h2 class="mb-1 text-2xl font-bold text-white">Application Settings</h2>
    <p class="text-sm text-gray-500">
      Notifikasi suara dan riwayat sesi di perangkat ini
    </p>
  </div>
  <div class="space-y-8">
    <section>
      <div class="mb-4 flex items-center justify-between gap-4">
        <div class="min-w-0">
          <Label variant="subsection" as="h3">Sound Notifications</Label>
          <Label variant="muted" class="mt-1 block">
            Bunyi saat tracking / scraping selesai
          </Label>
        </div>
        <div class="flex shrink-0 items-center gap-3">
          <span
            id="notification-sound-state"
            class="text-[10px] font-bold uppercase text-gray-400">On</span
          >
          <label class="relative inline-flex cursor-pointer items-center">
            <input
              type="checkbox"
              id="notification-sound-toggle"
              class="peer sr-only"
              checked
            />
            <div
              class="peer h-6 w-11 rounded-full bg-gray-700 after:absolute after:inset-s-[2px] after:top-[2px] after:h-5 after:w-5 after:rounded-full after:border after:border-gray-300 after:bg-white after:transition-all after:content-[''] peer-checked:bg-[#0066cc] peer-checked:after:translate-x-full peer-focus:outline-none"
            >
            </div>
          </label>
        </div>
      </div>
      <div class="space-y-2">
        <Label variant="field" for="notification-sound-select">
          Notification Sound
        </Label>
        <Input
          variant="select"
          id="notification-sound-select"
          showChevron={true}
        >
          <option value="bell">Bell (Default)</option>
          <option value="chime">Chime</option>
          <option value="notification">Notification</option>
          <option value="success">Success Tone</option>
          <option value="alert">Alert Beep</option>
        </Input>
      </div>
    </section>
    <section>
      <Label variant="subsection" as="h3" class="mb-4">
        Previous Tracking Sessions
      </Label>
      <div
        class="overflow-hidden rounded-xl border border-[#2d2d2d] bg-[#1f1f1f]"
      >
        <div class="max-h-60 overflow-y-auto custom-scrollbar">
          <table class="w-full border-collapse text-left">
            <thead
              class="sticky top-0 z-10 border-b border-[#2d2d2d] bg-[#161616]"
            >
              <tr
                class="text-[9px] font-bold uppercase tracking-widest text-gray-500"
              >
                <th class="w-10 px-4 py-3">
                  <Input
                    variant="checkbox"
                    id="settings-sessions-select-all"
                    checkboxClass="rounded border-[#2d2d2d] bg-[#1a1a1a] text-[#0066cc] focus:ring-0"
                    title="Pilih semua"
                  />
                </th>
                <th class="px-4 py-3">Date / Session</th>
                <th class="px-4 py-3">Location</th>
                <th class="px-4 py-3 text-right">Results</th>
              </tr>
            </thead>
            <tbody
              id="settings-sessions-tbody"
              class="divide-y divide-[#2d2d2d]"
            >
            </tbody>
          </table>
        </div>
      </div>
      <div
        class="mt-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between"
      >
        <div class="flex flex-wrap gap-2">
          <Button
            variant="settingsBar"
            type="button"
            id="settings-sessions-restore"
          >
            <iconify-icon icon="lucide:refresh-cw"></iconify-icon> Restore Selected
          </Button>
          <Button
            variant="dangerBar"
            type="button"
            id="settings-sessions-delete"
          >
            <iconify-icon icon="lucide:trash-2"></iconify-icon> Delete Selected
          </Button>
        </div>
        <Button variant="textLink" type="button" id="settings-sessions-clear">
          Clear All History
        </Button>
      </div>
    </section>
  </div>
  <div class="mt-10 flex justify-end border-t border-[#2d2d2d] pt-6">
    <Button variant="primaryAction" type="button" id="settings-save-btn">
      Save &amp; Apply Changes
    </Button>
  </div>
</Dialog>
